model User {
   id         String      @id @default(uuid())
   name       String      @db.VarChar(255)
   email      String      @unique
   password   String
   role       Role
   status     Status      @default(ACTIVE)
   createdAt  DateTime    @default(now())
   updatedAt  DateTime    @updatedAt
   properties Propertie[]
   payments   Payment[]
   review     Review[]
   rental     Rental[]

   @@map("users")
}
